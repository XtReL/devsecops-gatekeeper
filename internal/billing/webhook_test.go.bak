// Тест: Webhook Signature Verification
// ПРИМЕЧАНИЕ: В реальности используй Stripe Test Mode и их Test Secrets
func TestWebhookSignatureVerification(t *testing.T) {
	// Это демонстрирует, как должна выглядеть верификация
	// Stripe использует HMAC-SHA256 для подписей

	testSecret := "whsec_test_secret_123"
	testPayload := []byte(`{
		"id":"evt_test",
		"type":"checkout.session.completed",
		"data":{
			"object":{
				"id":"cs_test",
				"metadata":{"tenant_id":"12345"}
			}
		}
	}`)
	_ = testSecret
	_ = testPayload

	// В реальном тесте:
	// sig := webhook.GenerateTestSignature(testPayload, testSecret)
	// req.Header.Set("Stripe-Signature", sig)

	// Для этого примера просто проверяем, что метод вызывается
	if testSecret == "" {
		t.Error("Secret should not be empty")
	}
}

